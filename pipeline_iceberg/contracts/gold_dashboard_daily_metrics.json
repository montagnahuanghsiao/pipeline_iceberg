{
  "dataset": "gold_dashboard_daily_metrics",
  "purpose": "Chart-ready daily dashboard indicators for sustainability, fishing-ground environment, and fishing activity.",
  "grain": "one row per event_date, aoi_id and resolution_km",
  "source_tables": ["gold_map_metric"],
  "date_scope": "2024-01-01 to pipeline end date by default",
  "unique_key": ["event_date", "aoi_id", "resolution_km"],
  "fields": {
    "event_date": "date",
    "aoi_id": "string",
    "resolution_km": "integer",
    "cell_count": "long",
    "data_coverage": "double",
    "chlor_a_avg": "double",
    "sea_temperature_avg": "double",
    "ocean_productivity_avg": "double",
    "sustainability_pressure_avg": "double",
    "sustainability_pressure_p90": "double",
    "fishing_hours_total": "double",
    "active_cell_ratio": "double",
    "high_activity_cell_ratio": "double",
    "high_productivity_cell_ratio": "double",
    "high_pressure_cell_ratio": "double",
    "share_of_all_fishing_hours": "double",
    "fishing_hours_7d_avg": "double",
    "sustainability_pressure_7d_avg": "double",
    "chlor_a_score_avg": "double",
    "sea_temperature_score_avg": "double",
    "ocean_productivity_score_avg": "double",
    "sustainability_pressure_score_avg": "double",
    "fishing_hours_score_avg": "double",
    "updated_at_utc": "timestamp",
    "pipeline_version": "string"
  },
  "nullable_metric_fields": [
    "chlor_a_avg",
    "sea_temperature_avg",
    "ocean_productivity_avg",
    "sustainability_pressure_avg",
    "sustainability_pressure_p90",
    "high_productivity_cell_ratio",
    "high_pressure_cell_ratio",
    "sustainability_pressure_7d_avg",
    "chlor_a_score_avg",
    "sea_temperature_score_avg",
    "ocean_productivity_score_avg",
    "sustainability_pressure_score_avg"
  ],
  "missing_policy": "An unavailable source metric remains null; available daily indicators continue to be published.",
  "partition_by": ["event_date", "aoi_id", "resolution_km"]
}
