apiVersion: batch/v1
kind: Job
metadata: {name: ocean-gold, namespace: dt}
spec:
  backoffLimit: 0
  activeDeadlineSeconds: 43200
  template:
    metadata:
      labels: {app: ocean-pipeline, stage: gold}
    spec:
      restartPolicy: Never
      nodeSelector: {kubernetes.io/hostname: tkdt-worker3}
      imagePullSecrets:
        - name: dkreg
      dnsPolicy: None
      dnsConfig:
        nameservers:
          - 10.98.136.10
        searches:
          - svc-dt.dt.svc.tkdt.k8s
          - dt.svc.tkdt.k8s
          - svc.tkdt.k8s
      securityContext: {runAsUser: 1000, runAsGroup: 1001, fsGroup: 1001}
      containers:
        - name: spark-submit
          image: dkreg.taroko:5000/ocean-spark-client:3.5.8
          command: ["/bin/bash", "/opt/zfs/project/pipeline_iceberg/scripts/run_gold.sh"]
          envFrom: [{configMapRef: {name: ocean-pipeline-config}}]
          env:
            - name: SPARK_DRIVER_HOST
              valueFrom: {fieldRef: {fieldPath: status.podIP}}
          volumeMounts:
            - {name: project, mountPath: /opt/zfs/project}
            - {name: system, mountPath: /opt/zfs/sys, readOnly: true}
          resources:
            requests: {cpu: 500m, memory: 1Gi}
            #limits: {cpu: "2", memory: 2Gi}
      volumes:
        - {name: project, hostPath: {path: /opt/zfs/project, type: Directory}}
        - {name: system, hostPath: {path: /opt/zfs/sys, type: Directory}}
