apiVersion: v1
kind: ConfigMap
metadata:
  name: ocean-pipeline-config
  namespace: dt
data:
  PROJECT_ROOT: /opt/zfs/project
  LOCAL_BRONZE_ROOT: /opt/zfs/project/data/bronze
  LOCAL_SERVING_ROOT: /opt/zfs/project/data/serving
  LOCAL_SERVING_CURRENT: /opt/zfs/project/data/serving/current
  HDFS_BRONZE_ROOT: hdfs:///raw/ocean/bronze
  HDFS_SILVER_ROOT: hdfs:///elt/ocean/silver
  HDFS_SERVING_ROOT: hdfs:///dataset/ocean/serving
  HDFS_METADATA_ROOT: hdfs:///metadata/ocean
  ICEBERG_WAREHOUSE: hdfs:///dataset/ocean/warehouse
  ICEBERG_CATALOG: lake
  ICEBERG_NAMESPACE: ocean
  AOI_IDS: taiwan
  START_DATE: "2024-12-01"
  END_DATE: "2024-12-07"
  FILL_WINDOW_DAYS: "3"
  SERVING_RELEASE_ID: "2024_12_01_07"
  SPARK_HOME: /opt/zfs/sys/spark-3.5.8-bin-hadoop3
  HADOOP_HOME: /opt/zfs/sys/hadoop-3.5.0
  HADOOP_CONF_DIR: /opt/zfs/sys/hadoop-3.5.0/etc/hadoop
  YARN_CONF_DIR: /opt/zfs/sys/hadoop-3.5.0/etc/hadoop
  JAVA_HOME: /opt/java/openjdk
  ICEBERG_JAR: /opt/zfs/sys/spark-3.5.8-bin-hadoop3/jars/iceberg-spark-runtime-3.5_2.12-1.11.0.jar
  SILVER_WRITE_SHARDS: "8"
  MAX_RECORDS_PER_FILE: "2000000"
  SPARK_EXECUTOR_INSTANCES: "2"
  SPARK_EXECUTOR_CORES: "1"
  SPARK_EXECUTOR_MEMORY: 1g
  SPARK_EXECUTOR_MEMORY_OVERHEAD: 512m
  SPARK_DRIVER_MEMORY: 1g
  SPARK_SHUFFLE_PARTITIONS: "24"
  SPARK_ADVISORY_PARTITION_SIZE: "67108864"
  API_CORS_ORIGINS: "*"
  API_MAX_GRID_CELLS: "100000"
